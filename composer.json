{
  "name": "devmehq/world-countries",
  "version": "1.0.0",
  "description": "Comprehensive world countries data including names, codes, capitals, currencies, languages, timezones, flags, and more - REST Countries v3.1 compatible",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "countries",
    "world",
    "country-codes",
    "country-data",
    "iso-3166",
    "iso-3166-1",
    "alpha-2",
    "alpha-3",
    "capitals",
    "currencies",
    "languages",
    "phone-codes",
    "calling-codes",
    "timezones",
    "continents",
    "regions",
    "subregions",
    "flags",
    "emoji-flags",
    "demonyms",
    "translations",
    "coordinates",
    "borders",
    "landlocked",
    "area",
    "population",
    "gini",
    "fifa",
    "rest-countries",
    "json",
    "php",
    "devme",
    "dev.me"
  ],
  "homepage": "https://github.com/devmehq/world-countries",
  "authors": [
    {
      "name": "DEV.ME Team",
      "email": "support@dev.me",
      "homepage": "https://dev.me"
    }
  ],
  "support": {
    "issues": "https://github.com/devmehq/world-countries/issues",
    "source": "https://github.com/devmehq/world-countries",
    "docs": "https://github.com/devmehq/world-countries#readme"
  },
  "require": {
    "php": ">=7.3",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5.22",
    "squizlabs/php_codesniffer": "^3.7",
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.16"
  },
  "autoload": {
    "psr-4": {
      "DevMe\\WorldCountries\\": "src/php/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "DevMe\\WorldCountries\\Tests\\": "tests/php/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-html coverage",
    "cs": "phpcs",
    "cs-fix": "phpcbf",
    "stan": "phpstan analyse src",
    "format": "php-cs-fixer fix --config=.php-cs-fixer.php",
    "format:check": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
    "check": [
      "@cs",
      "@stan",
      "@test"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}