{
  "name": "@devmehq/world-countries",
  "version": "1.0.0",
  "description": "Comprehensive world countries data including names, codes, capitals, currencies, languages, and more - REST Countries v3.1 compatible",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "author": {
    "name": "DEV.ME",
    "email": "support@dev.me",
    "url": "https://dev.me"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/devmehq/world-countries"
  },
  "bugs": {
    "url": "https://github.com/devmehq/world-countries/issues"
  },
  "homepage": "https://github.com/devmehq/world-countries#readme",
  "keywords": [
    "countries",
    "world",
    "country-codes",
    "country-data",
    "iso-3166",
    "iso-3166-1",
    "alpha-2",
    "alpha-3",
    "capitals",
    "currencies",
    "languages",
    "phone-codes",
    "calling-codes",
    "timezones",
    "continents",
    "regions",
    "subregions",
    "flags",
    "emoji-flags",
    "demonyms",
    "translations",
    "coordinates",
    "borders",
    "landlocked",
    "area",
    "population",
    "gini",
    "fifa",
    "rest-countries",
    "json",
    "typescript",
    "javascript",
    "nodejs",
    "react",
    "vue",
    "angular",
    "devme",
    "dev.me"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run build",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/devmehq"
  }
}